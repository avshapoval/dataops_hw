{
  "dashboard": {
    "title": "Monitoring Dashboard",
    "panels": [
      {
        "id": 1,
        "title": "Prometheus Query Range Requests",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(prometheus_http_requests_total{handler=\"/api/v1/query_range\"}[1m])",
            "legendFormat": "Query Range Requests"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "CPU Usage by Mode",
        "type": "graph",
        "targets": [
          {
            "expr": "avg by (mode) (rate(node_cpu_seconds_total[1m]))",
            "legendFormat": "{{mode}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "ML Service Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(starlette_requests_total[1m])",
            "legendFormat": "{{method}} {{path_template}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "ML Service Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(starlette_request_duration_seconds_bucket[1m]))",
            "legendFormat": "p95"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      }
    ],
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    }
  }
}
